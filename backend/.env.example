# Use this when the backend runs inside Docker Compose.
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://requirements_app:requirements_app@db:5432/requirements_intelligence
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# FRONTEND_ORIGIN_REGEX=^https://.*\\.vercel\\.app$
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# If you run backend commands directly on Windows instead of in Docker,
# use localhost instead of db:
# DATABASE_URL=postgresql+psycopg://requirements_app:requirements_app@localhost:5432/requirements_intelligence

# Requirement generation provider selection:
REQUIREMENT_GENERATION_PROVIDER=mock
REQUIREMENT_GENERATION_FALLBACK_TO_MOCK=true

# OpenAI provider configuration:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=
# OPENAI_TIMEOUT_SECONDS=30
# OPENAI_MAX_RETRIES=1

# Agent-validation configuration:
# AGENT_TRIAGE_MODEL=gpt-5.4-nano
# AGENT_DEEP_REVIEW_MODEL=gpt-5.4-mini
# AGENT_EMBEDDING_MODEL=text-embedding-3-small
# AGENT_CHUNK_SIZE=900
# AGENT_CHUNK_OVERLAP=150
# AGENT_TOP_K_CHUNKS=5
# AGENT_MAX_RETRIEVED_CHARS=3500
# AGENT_MAX_DUPLICATE_CANDIDATES=3
# AGENT_TRIAGE_CONFIDENCE_THRESHOLD=0.78
# AGENT_OPENAI_TIMEOUT_SECONDS=30
# AGENT_OPENAI_MAX_RETRIES=1

# Authentication:
# AUTH_COOKIE_NAME=rip_session
# AUTH_SESSION_HOURS=72
# AUTH_DEFAULT_USERNAME=demo
# AUTH_DEFAULT_PASSWORD=demo1234
# AUTH_DEFAULT_DISPLAY_NAME=Demo Engineer
